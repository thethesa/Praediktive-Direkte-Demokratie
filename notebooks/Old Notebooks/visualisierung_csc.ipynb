    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"bb12f74f953b1a45\",\n",
    "   \"metadata\": {\n",
    "    \"collapsed\": false,\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-11T21:41:44.970170Z\",\n",
    "     \"start_time\": \"2026-03-11T21:41:44.645874Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"data['datum'] = pd.to_datetime(data['datum'], format='%d.%m.%Y')\\n\",\n",
    "    \"\\n\",\n",
    "    \"data.replace([9999,999], np.nan, inplace=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Kongruenz-Spalte erstellen (Regierungstreue)\\n\",\n",
    "    \"#br-pos: 1 = Ja, 2 = Nein, 8 = Vorzug Gegenentwurf, 9 = Vorzug Initiative| Volksmehr: 1 = Angenommen, 0 = Abgelehnt, 8 = Vorzug Gegenentwurf\\n\",\n",
    "    \"\\n\",\n",
    "    \"data['regierungstreue'] = np.where(\\n\",\n",
    "    \"     ((data['br-pos'] == 1) & (data['volk'] == 1)) |\\n\",\n",
    "    \"     ((data['br-pos'] == 2) & (data['volk'] == 0)) |\\n\",\n",
    "    \"     ((data['br-pos'] == 8) & (data['volk'] == 8)) |\\n\",\n",
    "    \"    ((data['br-pos'] == 9) & (data['volk'] == 9)),\\n\",\n",
    "    \"     1,\\n\",\n",
    "    \"     0\\n\",\n",
    "    \" )\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"data['regierungstreue'] = np.where(\\n\",\n",
    "    \"    data['br-pos'].isin([1, 2]),\\n\",\n",
    "    \"    np.where(\\n\",\n",
    "    \"        ((data['br-pos'] == 1) & (data[\\\"volkja-proz\\\"] > 50.0)) |\\n\",\n",
    "    \"        ((data['br-pos'] == 2) & (data[\\\"volkja-proz\\\"] < 50.0)),\\n\",\n",
    "    \"        1,\\n\",\n",
    "    \"        0\\n\",\n",
    "    \"    ),\\n\",\n",
    "    \"    np.nan\\n\",\n",
    "    \")\\n\",\n",
    "    \"for col in ['d1e1', 'd1e2', 'd1e3', 'd2e1', 'd2e2', 'd2e3', 'd3e1', 'd3e2', 'd3e3']:\\n\",\n",
    "    \"    print(f\\\"\\\\n{col}\\\")\\n\",\n",
    "    \"    print(data[col].value_counts(dropna=False).head(20))\\n\",\n",
    "    \"    \\n\",\n",
    "    \"hauptgruppen_map = {\\n\",\n",
    "    \"    1: 'Staatsordnung & Politische Rechte',\\n\",\n",
    "    \"    2: 'EU & Aussenpolitik',\\n\",\n",
    "    \"    3: 'Armee & Sicherheit',\\n\",\n",
    "    \"    4: 'Wirtschaft & Arbeit',\\n\",\n",
    "    \"    5: 'Landwirtschaft',\\n\",\n",
    "    \"    6: 'Finanzen & Steuern',\\n\",\n",
    "    \"    7: 'Energie',\\n\",\n",
    "    \"    8: 'Verkehr & Infrastruktur',\\n\",\n",
    "    \"    9: 'Klima & Umwelt',\\n\",\n",
    "    \"    10: 'Soziale Sicherheit & Gesellschaft',\\n\",\n",
    "    \"    11: 'Bildung & Forschung',\\n\",\n",
    "    \"    12: 'Kultur, Religion & Medien'\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"data['Hauptgruppe'] = data['d1e1'].map(hauptgruppen_map)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def assign_hauptgruppe(row):\\n\",\n",
    "    \"    d1 = row['d1e1']\\n\",\n",
    "    \"    d2 = row['d1e2']\\n\",\n",
    "    \"    d3 = row['d1e3']\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if d1 == 10:\\n\",\n",
    "    \"        if d2 == 1:\\n\",\n",
    "    \"            return 'Gesundheit'\\n\",\n",
    "    \"        elif d2 == 2:\\n\",\n",
    "    \"            return 'Soziale Sicherheit'\\n\",\n",
    "    \"        elif d2 == 3:\\n\",\n",
    "    \"            return 'Migration & Gesellschaft'\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            return 'Soziale Sicherheit & Gesellschaft'\\n\",\n",
    "    \"\\n\",\n",
    "    \"    elif d1 == 11:\\n\",\n",
    "    \"        return 'Bildung & Forschung'\\n\",\n",
    "    \"    elif d1 == 12:\\n\",\n",
    "    \"        return 'Kultur, Religion & Medien'\\n\",\n",
    "    \"    elif d1 == 2:\\n\",\n",
    "    \"        return 'EU & Aussenpolitik'\\n\",\n",
    "    \"    elif d1 == 3:\\n\",\n",
    "    \"        return 'Armee & Sicherheit'\\n\",\n",
    "    \"    elif d1 in [7, 9]:\\n\",\n",
    "    \"        return 'Klima & Umwelt'\\n\",\n",
    "    \"    elif d1 == 6:\\n\",\n",
    "    \"        return 'Finanzen & Steuern'\\n\",\n",
    "    \"    elif d1 == 8:\\n\",\n",
    "    \"        return 'Verkehr & Infrastruktur'\\n\",\n",
    "    \"    elif d1 == 4:\\n\",\n",
    "    \"        return 'Wirtschaft & Arbeit'\\n\",\n",
    "    \"    elif d1 == 5:\\n\",\n",
    "    \"        return 'Landwirtschaft'\\n\",\n",
    "    \"    elif d1 == 1:\\n\",\n",
    "    \"        return 'Staatsordnung & Politische Rechte'\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        return 'Andere'\\n\",\n",
    "    \"    \\n\",\n",
    "    \"data['Hauptgruppe'] = data.apply(assign_hauptgruppe, axis=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"data['Hauptgruppe'].value_counts(dropna=False)\\n\",\n",
    "    \"data[['titel_kurz_d', 'd1e1', 'd1e2', 'd1e3', 'Hauptgruppe']].sample(20, random_state=42)\\n\",\n",
    "    \"data[data['Hauptgruppe'].isna()][['titel_kurz_d', 'd1e1', 'd1e2', 'd1e3']].head(20)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Labels für die Spalte Rechtsform vergeben\\n\",\n",
    "    \"rechtsform_map = {\\n\",\n",
    "    \"    1: 'Obligatorisches Referendum',\\n\",\n",
    "    \"    2: 'Fakultatives Referendum',\\n\",\n",
    "    \"    3: 'Volksinitiative',\\n\",\n",
    "    \"    4: 'Direkter Gegenentwurf',\\n\",\n",
    "    \"    5: 'Stichfrage'\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"data['rechtsform_name'] = data['rechtsform'].map(rechtsform_map)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Abstimmungen in den Kantonen: Spalten ordnen\\n\",\n",
    "    \"kanton_cols = [col for col in data.columns if col.endswith('-japroz')]\\n\",\n",
    "    \"print(kanton_cols)\\n\",\n",
    "    \"print(len(kanton_cols))\\n\",\n",
    "    \"\\n\",\n",
    "    \"kanton_df = data.melt(\\n\",\n",
    "    \"    id_vars=['anr', 'titel_kurz_d', 'regierungstreue', 'br-pos', 'annahme'],\\n\",\n",
    "    \"    value_vars=kanton_cols,\\n\",\n",
    "    \"    var_name='Kanton',\\n\",\n",
    "    \"    value_name='Ja_Anteil'\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"kanton_df['Kanton'] = kanton_df['Kanton'].str.replace('-japroz', '', regex=False).str.upper()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Jahre umwandeln\\n\",\n",
    "    \"data['jahr'] = data['datum'].dt.year\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Vorbereitung für Visualisierungen\\n\",\n",
    "    \"plot_data = data[\\n\",\n",
    "    \"    data['br-pos'].isin([1, 2]) &\\n\",\n",
    "    \"    data['annahme'].isin([0, 1])\\n\",\n",
    "    \"].copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"### CHARLOTTE: WÜRDE für die meisten Analysen LEGISJAHR NEHMEN --> DEKADE LÖSCHEN\\n\",\n",
    "    \"plot_data['jahr'] = plot_data['datum'].dt.year\\n\",\n",
    "    \"plot_data['dekade'] = (plot_data['jahr'] // 10) * 10\\n\",\n",
    "    \"\\n\",\n",
    "    \"### CHARLOTTE: WÜRDE ICH NICHT SO MACHEN. GROSSER KONZEPTIONELLER UNTERSCHIED ZWISCHEN DEN BEIDEN.\\n\",\n",
    "    \"##plot_data['rechtsform_group'] = plot_data['rechtsform_name'].replace({\\n\",\n",
    "    \"#   'Obligatorisches Referendum': 'Referendum',\\n\",\n",
    "    \"#    'Fakultatives Referendum': 'Referendum'\\n\",\n",
    "    \"#})\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Kantonale Annahme-Spalten finden\\n\",\n",
    "    \"kanton_annahme_cols = [col for col in data.columns if col.endswith('-annahme')]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# In Long-Format bringen\\n\",\n",
    "    \"kanton_vote_df = data.melt(\\n\",\n",
    "    \"    id_vars=['anr', 'titel_kurz_d', 'br-pos'],\\n\",\n",
    "    \"    value_vars=kanton_annahme_cols,\\n\",\n",
    "    \"    var_name='Kanton',\\n\",\n",
    "    \"    value_name='kanton_annahme'\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Kantonskürzel bereinigen\\n\",\n",
    "    \"kanton_vote_df['Kanton'] = kanton_vote_df['Kanton'].str.replace('-annahme', '', regex=False).str.upper()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Nur klare Fälle behalten\\n\",\n",
    "    \"kanton_vote_df = kanton_vote_df[\\n\",\n",
    "    \"    kanton_vote_df['br-pos'].isin([1, 2]) &\\n\",\n",
    "    \"    kanton_vote_df['kanton_annahme'].isin([0, 1])\\n\",\n",
    "    \"].copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Kantonale Regierungstreue berechnen\\n\",\n",
    "    \"kanton_vote_df['kanton_regierungstreue'] = np.where(\\n\",\n",
    "    \"    ((kanton_vote_df['br-pos'] == 1) & (kanton_vote_df['kanton_annahme'] == 1)) |\\n\",\n",
    "    \"    ((kanton_vote_df['br-pos'] == 2) & (kanton_vote_df['kanton_annahme'] == 0)),\\n\",\n",
    "    \"    1,\\n\",\n",
    "    \"    0\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Sprachregionen zuordnen\\n\",\n",
    "    \"sprachregion_map = {\\n\",\n",
    "    \"    'ZH': 'Deutschschweiz', 'BE': 'Deutschschweiz', 'LU': 'Deutschschweiz',\\n\",\n",
    "    \"    'UR': 'Deutschschweiz', 'SZ': 'Deutschschweiz', 'OW': 'Deutschschweiz',\\n\",\n",
    "    \"    'NW': 'Deutschschweiz', 'GL': 'Deutschschweiz', 'ZG': 'Deutschschweiz',\\n\",\n",
    "    \"    'FR': 'Romandie', 'SO': 'Deutschschweiz', 'BS': 'Deutschschweiz',\\n\",\n",
    "    \"    'BL': 'Deutschschweiz', 'SH': 'Deutschschweiz', 'AR': 'Deutschschweiz',\\n\",\n",
    "    \"    'AI': 'Deutschschweiz', 'SG': 'Deutschschweiz', 'GR': 'Deutschschweiz',\\n\",\n",
    "    \"    'AG': 'Deutschschweiz', 'TG': 'Deutschschweiz', 'TI': 'Tessin',\\n\",\n",
    "    \"    'VD': 'Romandie', 'VS': 'Romandie', 'NE': 'Romandie',\\n\",\n",
    "    \"    'GE': 'Romandie', 'JU': 'Romandie'\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Pro Kanton mitteln\\n\",\n",
    "    \"kanton_summary = (\\n\",\n",
    "    \"    kanton_vote_df.groupby('Kanton', as_index=False)['kanton_regierungstreue']\\n\",\n",
    "    \"    .mean()\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"kanton_summary['Sprachregion'] = kanton_summary['Kanton'].map(sprachregion_map)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Nach Regierungstreue sortieren\\n\",\n",
    "    \"kanton_summary = kanton_summary.sort_values('kanton_regierungstreue')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Kantons-Spalten\\n\",\n",
    "    \"kanton_cols = [col for col in data.columns if col.endswith('-japroz')]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Long-Format: jede Abstimmung x jeder Kanton\\n\",\n",
    "    \"heatmap_df = data.melt(\\n\",\n",
    "    \"    id_vars=['anr', 'titel_kurz_d', 'Hauptgruppe'],\\n\",\n",
    "    \"    value_vars=kanton_cols,\\n\",\n",
    "    \"    var_name='Kanton',\\n\",\n",
    "    \"    value_name='Ja_Anteil'\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Kantonsnamen bereinigen\\n\",\n",
    "    \"heatmap_df['Kanton'] = heatmap_df['Kanton'].str.replace('-japroz', '', regex=False).str.upper()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Ja-Anteil numerisch\\n\",\n",
    "    \"heatmap_df['Ja_Anteil'] = pd.to_numeric(heatmap_df['Ja_Anteil'], errors='coerce')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Fehlende Werte entfernen\\n\",\n",
    "    \"heatmap_df = heatmap_df.dropna(subset=['Ja_Anteil', 'Hauptgruppe'])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Durchschnittlicher Ja-Anteil pro Hauptgruppe und Kanton\\n\",\n",
    "    \"heatmap_data = (\\n\",\n",
    "    \"    heatmap_df.groupby(['Hauptgruppe', 'Kanton'])['Ja_Anteil']\\n\",\n",
    "    \"    .mean()\\n\",\n",
    "    \"    .reset_index()\\n\",\n",
    "    \"    .pivot(index='Hauptgruppe', columns='Kanton', values='Ja_Anteil')\\n\",\n",
    "    \")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"\\n\",\n",
    "      \"d1e1\\n\",\n",
    "      \"d1e1\\n\",\n",
    "      \"10    142\\n\",\n",
    "      \"1     107\\n\",\n",
    "      \"4      86\\n\",\n",
    "      \"6      71\\n\",\n",
