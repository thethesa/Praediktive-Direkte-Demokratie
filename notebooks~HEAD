    "def calc(row):\n",
    "    if pd.isna(row['br-pos']) or pd.isna(row['annahme']):\n",
    "        return np.nan\n",
    "    if (row['br-pos'] == 1 and row['annahme'] == 1) or (row['br-pos'] == 2 and row['annahme'] == 0):\n",
    "        return 1\n",
    "    return 0\n",
    "data['regierungstreue'] = np.where(\n",
    "    ((data['br-pos'] == 1) & (data['annahme'] == 1)) |\n",
