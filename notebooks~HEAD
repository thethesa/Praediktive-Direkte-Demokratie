    "\n",
    "data['Hauptgruppe'] = data['d1e1'].map(hauptgruppen_map)\n",
    "\n",
    "\n",
    "def assign_hauptgruppe(row):\n",
    "    d1 = row['d1e1']\n",
    "    d2 = row['d1e2']\n",
    "    d3 = row['d1e3']\n",
    "\n",
