    "    1,\n",
    "    0\n",
    ")\n",
    "\n",
    "for col in ['d1e1', 'd1e2', 'd1e3', 'd2e1', 'd2e2', 'd2e3', 'd3e1', 'd3e2', 'd3e3']:\n",
